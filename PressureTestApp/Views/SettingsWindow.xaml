<Window x:Class="PressureTestApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="400" Width="450"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Название испытания:" Margin="0,0,0,5"/>
        <TextBox x:Name="TestNameBox" Grid.Row="1" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Тип эмуляции:" Margin="0,0,0,5"/>
        <ComboBox x:Name="TypeCombo" Grid.Row="3" Margin="0,0,0,15"/>

        <StackPanel x:Name="StaticPanel" Grid.Row="4">
            <TextBlock Text="Значение давления:" Margin="0,0,0,5"/>
            <TextBox x:Name="StaticValueBox"/>
        </StackPanel>

        <StackPanel x:Name="RampPanel" Grid.Row="4" Visibility="Collapsed">
            <TextBlock Text="Шаг изменения:" Margin="0,0,0,5"/>
            <TextBox x:Name="RampStepBox"/>
        </StackPanel>

        <StackPanel x:Name="RandomPanel" Grid.Row="4" Visibility="Collapsed">
            <TextBlock Text="Максимальное давление:" Margin="0,0,0,5"/>
            <TextBox x:Name="RandomLimitBox"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="80" Margin="0,0,10,0"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="80"/>
        </StackPanel>
    </Grid>
</Window>